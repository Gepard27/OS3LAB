#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WATCHER="${SCRIPT_DIR}/watcher.sh"


CONFIG="${SCRIPT_DIR}/watcher.conf"
PID_FILE="${SCRIPT_DIR}/watcher.pid"
LOG_FILE="${SCRIPT_DIR}/logs/watcher.log"
[[ -f "$CONFIG" ]] && source "$CONFIG"

get_pid() {
    [[ -f "$PID_FILE" ]] || return 1
    local pid
    pid=$(cat "$PID_FILE" 2>/dev/null) || return 1
    [[ -n "$pid" ]] && echo "$pid"
}

is_running() {
    local pid
    pid=$(get_pid 2>/dev/null) || return 1
    kill -0 "$pid" 2>/dev/null
}

cmd_start() {
    local extra_args=("$@")

    if is_running; then
        local pid; pid=$(get_pid)
        echo "Watcher already running (PID=$pid). Use 'restart' to restart."
        exit 1
    fi

    echo "Starting Watcher..."
    mkdir -p "$(dirname "$LOG_FILE")" "${SCRIPT_DIR}/archive" "${SCRIPT_DIR}/reports"

    nohup bash "$WATCHER" "${extra_args[@]}" >> "$LOG_FILE" 2>&1 &
    local pid=$!
    echo $pid > "$PID_FILE"

    local waited=0
    while (( waited < 5 )); do
        sleep 1
        (( waited++ )) || true
        if kill -0 "$pid" 2>/dev/null; then
            echo "Watcher started (PID=$pid)"
            return 0
        fi
    done

    echo "ERROR: Watcher failed to start. Check $LOG_FILE"
    rm -f "$PID_FILE"
    exit 1
}

cmd_stop() {
    if ! is_running; then
        echo "Watcher is not running."
        exit 0
    fi

    local pid; pid=$(get_pid)
    echo "Stopping Watcher (PID=$pid)..."
    kill -TERM "$pid" 2>/dev/null || true

    local waited=0
    while is_running && (( waited < 10 )); do
        sleep 1
        (( waited++ )) || true
        echo -n "."
    done
    echo

    if is_running; then
        echo "WARNING: Watcher did not stop gracefully — sending SIGKILL"
        kill -KILL "$pid" 2>/dev/null || true
        sleep 1
    fi

    rm -f "$PID_FILE"
    echo "Watcher stopped."
}

cmd_status() {
    if is_running; then
        local pid; pid=$(get_pid)
        local uptime_s
        uptime_s=$(ps -o etimes= -p "$pid" 2>/dev/null | tr -d ' ' || echo "?")
        local events
        events=$(grep "EVENT" "$LOG_FILE" 2>/dev/null | wc -l | tr -d ' ' || echo 0)
        local cmdline
        cmdline=$(ps -o args= -p "$pid" 2>/dev/null || echo "(unavailable)")

        echo "  Watcher is RUNNING"
        echo "  PID          : $pid"
        echo "  Uptime (sec) : $uptime_s"
        echo "  Command      : $cmdline"
        echo "  Log file     : $LOG_FILE"
        echo "  Events logged: $events"
        echo ""
        echo "--- Last 5 log lines ---"
        tail -n 5 "$LOG_FILE" 2>/dev/null || true
    else
        echo "  Watcher is STOPPED"
        if [[ -f "$PID_FILE" ]]; then
            echo "  (Stale PID file removed)"
            rm -f "$PID_FILE"
        fi
    fi
}

cmd_reload() {
    if ! is_running; then
        echo "Watcher is not running."
        exit 1
    fi
    local pid; pid=$(get_pid)
    kill -HUP "$pid"
    echo "SIGHUP sent to Watcher (PID=$pid) — config reload triggered."
}

cmd_restart() {
    local extra_args=("$@")
    cmd_stop
    sleep 1
    cmd_start "${extra_args[@]}"
}

CMD="${1:-}"
shift || true

case "$CMD" in
    start)   cmd_start   "$@" ;;
    stop)    cmd_stop         ;;
    status)  cmd_status       ;;
    reload)  cmd_reload       ;;
    restart) cmd_restart "$@" ;;
    *)
        echo "Usage: $0 {start|stop|status|restart|reload} [watcher options]"
        echo "  watcher options are passed directly to watcher.sh (see watcher.sh --help)"
        exit 1
        ;;
esac
